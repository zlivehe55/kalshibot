# Kalshi API
KALSHI_API_KEY=your_api_key_here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Market Selection
SERIES_TICKER=KXBTC15M           # Series ticker (KXBTC15M for 15-min)
SERIES_TICKERS=KXBTC15M,KXETH15M,KXSOL15M,KXXRP15M,KXDOGE15M
SLOT_DURATION=900                # Slot duration in seconds (900=15min)

# Strategy Thresholds
MIN_EDGE=5.0                     # Minimum edge % for Polymarket arbitrage
MIN_DIVERGENCE=8.0               # Minimum divergence % for directional (Binance spot) trades
TRADING_WINDOW=10                # Only trade first N minutes of each 15-min market

# Position Sizing
MAX_POSITION_SIZE=1.50           # Hard ceiling $ per trade
MAX_TOTAL_OPEN_POSITIONS=10      # Maximum concurrent positions
MAX_POSITIONS_PER_CONTRACT=1     # One position per ticker
MAX_ACCOUNT_RISK_PCT=0.35        # Stop bot if realized loss reaches 35% of start balance
USE_KELLY_SIZING=true            # Enable Kelly criterion sizing
KELLY_FRACTION=0.25              # Kelly fraction (0.25 = quarter Kelly, conservative)

# Supabase (for ML pipeline + Vercel deployment)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here

# Vercel Cron (auto-set by Vercel)
CRON_SECRET=your_cron_secret_here

# For Vercel: encode private key as base64 instead of file path
# KALSHI_PRIVATE_KEY_BASE64=base64_encoded_pem_contents

# Server
PORT=3333                        # Mission Control dashboard port
