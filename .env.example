# Kalshi API
KALSHI_API_KEY=your_api_key_here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Market Selection
SERIES_TICKER=KXBTC15M           # Series ticker (KXBTC15M for 15-min)
SLOT_DURATION=900                # Slot duration in seconds (900=15min)

# Strategy Thresholds
MIN_EDGE=5.0                     # Minimum edge % for Polymarket arbitrage
MIN_DIVERGENCE=8.0               # Minimum divergence % for directional (Binance spot) trades
TRADING_WINDOW=10                # Only trade first N minutes of each 15-min market

# Position Sizing
MAX_POSITION_SIZE=25             # Maximum $ per trade
MAX_TOTAL_OPEN_POSITIONS=10      # Maximum concurrent positions
MAX_POSITIONS_PER_CONTRACT=2     # Maximum positions on same contract
USE_KELLY_SIZING=true            # Enable Kelly criterion sizing
KELLY_FRACTION=0.25              # Kelly fraction (0.25 = quarter Kelly, conservative)

# Server
PORT=3333                        # Mission Control dashboard port
